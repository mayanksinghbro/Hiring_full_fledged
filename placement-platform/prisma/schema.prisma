// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// NEXT-AUTH REQUIRED MODELS
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())

  role      String  @default("student") // student | college_admin | company_hr
  college   College? @relation(fields: [collegeId], references: [id])
  collegeId String?
  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?

  accounts Account[]
  sessions Session[]
  student Student?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// COLLEGES
// ─────────────────────────────────────────────────────────────

model College {
  id        String   @id @default(cuid())
  name      String
  city      String?
  state     String?
  website   String?
  createdAt DateTime @default(now())

  users           User[]
  students        Student[]
  placementDrives PlacementDrive[]
}

// ─────────────────────────────────────────────────────────────
// COMPANIES
// ─────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  website   String?
  industry  String?
  logoUrl   String?
  createdAt DateTime @default(now())

  users           User[]
  jobPostings     JobPosting[]
  placementDrives PlacementDrive[]
  placementOffers PlacementOffer[]
  gapAnalyses     GapAnalysis[]
}

// ─────────────────────────────────────────────────────────────
// STUDENTS
// ─────────────────────────────────────────────────────────────

model Student {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String   @unique
  college    College? @relation(fields: [collegeId], references: [id])
  collegeId  String?
  rollNumber String?
  branch     String?
  batchYear  Int?
  cgpa       Decimal? @db.Decimal(3, 1)
  linkedin   String?
  github     String?
  portfolio  String?
  phone      String?
  isPlaced   Boolean  @default(false)
  createdAt  DateTime @default(now())

  readinessScore        Int?     @default(0)
  readinessBreakdown    Json?    // {skills: 0-100, resume: 0-100, practice: 0-100, projects: 0-100}
  improvementSuggestions Json?   // [{area, suggestion, priority}]

  skills          StudentSkill[]
  resumes         Resume[]
  applications    Application[]
  placementOffers PlacementOffer[]
  gapAnalyses     GapAnalysis[]
}

model Skill {
  id   String @id @default(cuid())
  name String @unique

  studentSkills   StudentSkill[]
  jobRequirements JobRequirement[]
}

model StudentSkill {
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId   String

  @@id([studentId, skillId])
}

model Resume {
  id          String   @id @default(cuid())
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  fileName    String?
  storagePath String?
  parsedText  String?  @db.Text
  isPrimary   Boolean  @default(true)
  uploadedAt  DateTime @default(now())

  applications Application[]
}

model PlacementDrive {
  id          String    @id @default(cuid())
  college     College   @relation(fields: [collegeId], references: [id])
  collegeId   String
  company     Company   @relation(fields: [companyId], references: [id])
  companyId   String
  driveDate   DateTime? @db.Date
  status      String    @default("upcoming")
  description String?
  createdAt   DateTime  @default(now())

  jobPostings JobPosting[]
}

model JobPosting {
  id          String          @id @default(cuid())
  drive       PlacementDrive? @relation(fields: [driveId], references: [id])
  driveId     String?
  company     Company         @relation(fields: [companyId], references: [id])
  companyId   String
  title       String
  description String?         @db.Text
  packageLpa  Decimal?        @db.Decimal(5, 2)
  roleType    String          @default("full_time")
  status      String          @default("active")
  createdAt   DateTime        @default(now())

  requirements    JobRequirement[]
  applications    Application[]
  placementOffers PlacementOffer[]
}

model JobRequirement {
  job     JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId   String
  skill   Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId String

  @@id([jobId, skillId])
}

model Application {
  id              String   @id @default(cuid())
  job             JobPosting @relation(fields: [jobId], references: [id])
  jobId           String
  student         Student  @relation(fields: [studentId], references: [id])
  studentId       String
  resume          Resume?  @relation(fields: [resumeId], references: [id])
  resumeId        String?
  matchScore      Decimal? @db.Decimal(5, 2)
  aiJustification String?  @db.Text
  status          String   @default("applied")
  shortlisted     Boolean  @default(false)
  appliedAt       DateTime @default(now())
  interviewRounds Json?    // [{round, type, date, status, feedback}]
  notes           String?  @db.Text

  placementOffer PlacementOffer?

  @@unique([jobId, studentId])
}

model PlacementOffer {
  id            String      @id @default(cuid())
  application   Application @relation(fields: [applicationId], references: [id])
  applicationId String      @unique
  student       Student     @relation(fields: [studentId], references: [id])
  studentId     String
  company       Company     @relation(fields: [companyId], references: [id])
  companyId     String
  job           JobPosting  @relation(fields: [jobId], references: [id])
  jobId         String
  packageLpa    Decimal?    @db.Decimal(5, 2)
  offerDate     DateTime?   @db.Date
  joiningDate   DateTime?   @db.Date
  status        String      @default("pending")
  createdAt     DateTime    @default(now())
}

model GapAnalysis {
  id         String   @id @default(cuid())
  student    Student  @relation(fields: [studentId], references: [id])
  studentId  String
  company    Company  @relation(fields: [companyId], references: [id])
  companyId  String
  targetRole String?
  createdAt  DateTime @default(now())

  gapItems     GapItem[]
  roadmapSteps RoadmapStep[]
  courses      Course[]
}

model GapItem {
  id            String      @id @default(cuid())
  gapAnalysis   GapAnalysis @relation(fields: [gapAnalysisId], references: [id], onDelete: Cascade)
  gapAnalysisId String
  skillName     String
  severity      String?
  description   String?
}

model RoadmapStep {
  id            String      @id @default(cuid())
  gapAnalysis   GapAnalysis @relation(fields: [gapAnalysisId], references: [id], onDelete: Cascade)
  gapAnalysisId String
  phase         String?
  title         String?
  description   String?
  stepType      String?
  orderIndex    Int         @default(0)
}

model Course {
  id            String      @id @default(cuid())
  gapAnalysis   GapAnalysis @relation(fields: [gapAnalysisId], references: [id], onDelete: Cascade)
  gapAnalysisId String
  title         String?
  platform      String?
  instructor    String?
  rating        Decimal?    @db.Decimal(2, 1)
  url           String?
  durationText  String?
  price         String?
  difficulty    String?     // beginner, intermediate, advanced
  category      String?     // skill gap area
  ratingsCount  Int?        @default(0)
}
